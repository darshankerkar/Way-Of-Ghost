# Server Production Environment
PORT=5000
NODE_ENV=production

# Client origin (your S3/CloudFront or Vercel URL)
CLIENT_ORIGIN=https://your-frontend-domain.com

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=your-strong-secret-min-12-chars
JWT_EXPIRES_IN=1d

# Admin credentials (for initial seed)
ADMIN_EMAIL=admin@gdg.local
ADMIN_PASSWORD=Admin@123

# Piston - use local Docker instance
PISTON_URL=http://localhost:2000/api/v2/piston/execute
