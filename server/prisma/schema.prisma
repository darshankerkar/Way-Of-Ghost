generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PARTICIPANT
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MatchupStatus {
  PENDING
  LIVE
  COMPLETED
}

enum RoundStatus {
  NOT_STARTED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  QUEUED
  ACCEPTED
  REJECTED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  name          String
  college       String
  role          Role         @default(PARTICIPANT)
  status        UserStatus   @default(PENDING)
  bits          Int          @default(0)
  eliminatedAt  DateTime?
  submissions   Submission[]

  matchupsAsUser1 Matchup[]  @relation("MatchUser1")
  matchupsAsUser2 Matchup[]  @relation("MatchUser2")
  wonMatchups     Matchup[]  @relation("MatchWinner")
  proctoringStatuses ProctoringStatus[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model EventState {
  id          String      @id @default("singleton")
  currentRound Int        @default(0)
  roundStatus RoundStatus @default(NOT_STARTED)
  updatedAt   DateTime    @updatedAt
}

model Problem {
  id          String       @id @default(cuid())
  title       String
  description String
  difficulty  String
  roundNumber Int
  hint        String?
  starterCode Json?
  timeLimit   Int          @default(900)
  testCases   TestCase[]
  matchups    Matchup[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TestCase {
  id         String  @id @default(cuid())
  problemId  String
  input      String
  expected   String
  isHidden   Boolean @default(true)
  problem    Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Matchup {
  id              String        @id @default(cuid())
  roundNumber     Int
  user1Id         String
  user2Id         String
  problemId       String
  winnerId        String?
  status          MatchupStatus @default(PENDING)
  startedAt       DateTime?
  endedAt         DateTime?
  timerExtension  Int           @default(0)
  user1           User          @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2           User          @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  winner          User?         @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  problem         Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id            String           @id @default(cuid())
  userId        String
  problemId     String
  code          String
  language      String
  status        SubmissionStatus @default(QUEUED)
  passedTests   Int              @default(0)
  totalTests    Int              @default(0)
  executionMs   Int?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem       Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
}



model ProctoringStatus {
  id             String   @id @default(cuid())
  userId         String
  roundNumber    Int
  fullscreen     Boolean  @default(false)
  tabSwitchCount Int      @default(0)
  warned         Boolean  @default(false)
  banned         Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roundNumber])
}


